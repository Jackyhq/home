{
  "installCommand": "npx pnpm@10 install --frozen-lockfile",
  "buildCommand": "npx pnpm@10 build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(www\\.)?jackyw\\.uk"
        }
      ],
      "destination": "/index-uk.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
